  cardsData:
  - id: Attack_JiJiRuLvLing_Water
    displayName: "\u6025\u6025\u5982\u5F8B\u4EE4"
    icon: {fileID: 21300000, guid: 410e4a076088b584a98cf98cdd891ae4, type: 3}
    portrait: {fileID: 21300000, guid: 410e4a076088b584a98cf98cdd891ae4, type: 3}
    pinned: 0
