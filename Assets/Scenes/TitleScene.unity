    tip: "\u300C\u6230\u9B25\u958B\u59CB\u6703\u751F\u6210\u6C34\u57DF\u3002\u300D\n\u300C\u5728\u6C34\u683C\u4E0A\u6703\u7372\u5F97\u8B77\u7532\u3002\u300D\n\u300C\u6F5B\u6C34\u7A81\u8972\u6703\u6D88\u5931\u4E26\u9396\u5B9A\u7BC4\u570D\u3002\u300D\n\u300C\u4E0B\u4E00\u56DE\u5408\u6703\u5C0D\u9396\u5B9A\u7BC4\u570D\u9020\u6210\u50B7\u5BB3\u4E26\u9644\u52A0\u865B\u5F31\u3002\u300D"
    skills:
    - icon: {fileID: 21300000, guid: 41e9cb84f376e974ca96159350e6d456, type: 3}
      skillName: "\u6C34\u57DF\u74B0\u7E5E"
      description: "\uFF08\u958B\u5834\uFF09\uFF1A\u751F\u6210\u6C34\u5143\u7D20\u5340\u57DF\u3002"
    - icon: {fileID: 21300000, guid: 988924e226818e24d8821418675c6f69, type: 3}
      skillName: "\u6F5B\u6C34\u7A81\u8972"
      description: "\uFF08\u4E3B\u52D5\uFF5C\u51B7\u537B\uFF1A2\uFF09\uFF1A\u6D88\u5931\u4E26\u9396\u5B9A\u7BC4\u570D\uFF0C\u4E0B\u56DE\u5408\u653B\u64CA\uFF08\u9644\u5E36\u865B\u5F31\uFF09\u3002"
    - icon: {fileID: 21300000, guid: c45d2d70a63f8244fb28f351c6d15693, type: 3}
      skillName: "\u6C34\u7532"
      description: "\uFF08\u88AB\u52D5\uFF09\uFF1A\u7AD9\u5728\u6C34\u683C\u6642\uFF0C\u56DE\u5408\u7D50\u675F\u7372\u5F97\u8B77\u7532\u3002"
