    areaSprite: {fileID: 21300000, guid: ff8fca13e71b907408da51cda9598a03, type: 3}
    intro: "\u7B26\u4EE4\u4E00\u51FA\uFF0C\u6CD5\u529B\u5373\u884C\u3002\u6B64\u8853\u4EE5\u7A69\u5B9A\u9748\u529B\u9A45\u52D5\uFF0C\u8FC5\u901F\u5C0D\u6575\u767C\u52D5\u653B\u64CA\uFF0C\u4E0D\u6C42\u6975\u81F4\u5A01\u529B\uFF0C\u800C\u91CD\u5728\u6301\u7E8C\u8F38\u51FA\u8207\u7BC0\u594F\u638C\u63A7\u3002\u65BC\u6230\u9B25\u4E4B\u4E2D\u53CD\u8986\u65BD\u5C55\uFF0C\u662F\u4FEE\u884C\u8005\u6700\u57FA\u790E\u4E14\u4E0D\u53EF\u6216\u7F3A\u7684\u653B\u64CA\u624B\u6BB5\u3002"
    concept: "\u7A69\u5B9A\u57FA\u790E\u653B\u64CA\uFF0C\u4F5C\u70BA\u5361\u7D44\u6838\u5FC3\u8F38\u51FA\u8207\u7BC0\u594F\u7DAD\u6301\u3002"
