  cardsData:
  - id: 'Attack_JiJiRuLvLing_Ice '
    displayName: "\u653B\u64CA_\u6025\u6025\u5982\u5F8B\u4EE4_\u51B0"
    icon: {fileID: 21300000, guid: 2238ee9772c409644953f98ef2db512f, type: 3}
    portrait: {fileID: 21300000, guid: 2238ee9772c409644953f98ef2db512f, type: 3}
    pinned: 0
    order: 0
    cardSprite: {fileID: 21300000, guid: 2238ee9772c409644953f98ef2db512f, type: 3}
    areaSprite: {fileID: 21300000, guid: ff8fca13e71b907408da51cda9598a03, type: 3}
    intro: "\u9053\u4EE4\u4E00\u51FA\uFF0C\u7B26\u6CD5\u5373\u6210\u3002\u6B64\u8853\u4EE5\u7A69\u5B9A\u70BA\u57FA\u790E\uFF0C\u8FC5\u901F\u767C\u52D5\u653B\u64CA\uFF0C\u4E0D\u8FFD\u6C42\u6975\u7AEF\u5A01\u529B\uFF0C\u800C\u662F\u8B1B\u6C42\u6E96\u78BA\u8207\u7BC0\u594F\u3002\u65BC\u6230\u9B25\u4E2D\u53CD\u8986\u65BD\u5C55\uFF0C\u6210\u70BA\u6700\u53EF\u9760\u7684\u57FA\u672C\u6253\u64CA\u624B\u6BB5\u3002"
    concept: "\u6A19\u6E96\u653B\u64CA\u5361\uFF0C\u7A69\u5B9A\u8F38\u51FA\uFF0C\u4F5C\u70BA\u6230\u9B25\u7BC0\u594F\u6838\u5FC3\u8207\u57FA\u790E\u50B7\u5BB3\u4F86\u6E90\u3002"
  - id: Attack_RanJinShu_Fire
    displayName: "\u653B\u64CA_\u71C3\u76E1\u8853_\u706B"
    icon: {fileID: 21300000, guid: 0f88ac8f8520e124eb6a3445223f1fd7, type: 3}
    portrait: {fileID: 21300000, guid: 0f88ac8f8520e124eb6a3445223f1fd7, type: 3}
    pinned: 0
    order: 1
    cardSprite: {fileID: 21300000, guid: 0f88ac8f8520e124eb6a3445223f1fd7, type: 3}
    areaSprite: {fileID: 21300000, guid: 9647fa6ea662c504e8cf1e648de21457, type: 3}
    intro: "\u4EE5\u72C2\u70C8\u4E4B\u706B\u51DD\u65BC\u7B26\u4E2D\uFF0C\u4E00\u64CA\u91CB\u653E\u6240\u6709\u7A4D\u84C4\u7684\u529B\u91CF\u3002\u6B64\u8853\u8FFD\u6C42\u6975\u81F4\u7834\u58DE\uFF0C\u5728\u77ED\u77AC\u4E4B\u9593\u7206\u767C\u51FA\u9A5A\u4EBA\u5A01\u529B\uFF0C\u711A\u71D2\u6575\u4EBA\u8089\u8EAB\u8207\u6C23\u8108\u3002\u7136\u800C\u706B\u52E2\u904E\u76DB\uFF0C\u7B26\u5492\u4EA6\u96A8\u4E4B\u71C3\u76E1\uFF0C\u4E00\u65E6\u65BD\u5C55\uFF0C\u4FBF\u4E0D\u518D\u7559\u5B58\u3002"
    concept: "\u9AD8\u50B7\u5BB3\u4E00\u6B21\u6027\u8F38\u51FA\uFF0C\u4F7F\u7528\u5F8C\u6D88\u8017\u5361\u724C\uFF0C\u4E3B\u6253\u7206\u767C\u8207\u8CC7\u6E90\u8F49\u63DB\u3002"
  - id: 'Attack_TianFa_Thunder  '
    displayName: "\u653B\u64CA_\u5929\u7F70_\u96F7"
    icon: {fileID: 21300000, guid: 4c042c478f4ec4e4289eff3aec1669ae, type: 3}
    portrait: {fileID: 21300000, guid: 4c042c478f4ec4e4289eff3aec1669ae, type: 3}
    pinned: 0
    order: 2
    cardSprite: {fileID: 21300000, guid: 4c042c478f4ec4e4289eff3aec1669ae, type: 3}
    areaSprite: {fileID: 21300000, guid: b39a261a494cdf34788dd4811934adb8, type: 3}
    intro: "\u5F15\u52D5\u5929\u96F7\u964D\u4E16\uFF0C\u5316\u70BA\u5BE9\u5224\u4E4B\u64CA\u3002\u96F7\u5149\u81EA\u9060\u65B9\u843D\u4E0B\uFF0C\u6A6B\u6383\u5927\u7247\u5340\u57DF\uFF0C\u51E1\u6240\u53CA\u4E4B\u8655\u7686\u96E3\u4EE5\u5016\u514D\u3002\u6B64\u8853\u5A01\u529B\u9A5A\u4EBA\uFF0C\u9069\u5408\u5728\u6575\u7FA4\u805A\u96C6\u4E4B\u6642\u65BD\u5C55\uFF0C\u4E00\u64CA\u6539\u8B8A\u6230\u5C40\u3002"
    concept: "\u9060\u8DDD\u96E2\u7BC4\u570D\u653B\u64CA\uFF0C\u9069\u5408\u6E05\u5834\u8207\u540C\u6642\u58D3\u5236\u591A\u500B\u6575\u4EBA\u3002"
  - id: 'Skill_HuWoZhenShen '
    displayName: "\u6CD5\u8853_\u8B77\u6211\u771F\u8EAB"
    icon: {fileID: 21300000, guid: 594f2c1ab6586eb4a9eb8c0a92ec71b2, type: 3}
    portrait: {fileID: 21300000, guid: 594f2c1ab6586eb4a9eb8c0a92ec71b2, type: 3}
    pinned: 0
    order: 3
    cardSprite: {fileID: 21300000, guid: 594f2c1ab6586eb4a9eb8c0a92ec71b2, type: 3}
    areaSprite: {fileID: 21300000, guid: 451d6cb975499b148879f40973398d9d, type: 3}
    intro: "\u51DD\u795E\u5B88\u4E00\uFF0C\u771F\u6C23\u74B0\u7E5E\u65BC\u8EAB\uFF0C\u7B26\u5370\u5316\u70BA\u7121\u5F62\u5C4F\u969C\u3002\u6B64\u8853\u53EF\u5728\u95DC\u9375\u6642\u523B\u62B5\u64CB\u6575\u65B9\u653B\u52E2\uFF0C\u4F7F\u65BD\u8853\u8005\u7A69\u4F4F\u9663\u8173\uFF0C\u4E0D\u88AB\u8F15\u6613\u64CA\u7834\uFF0C\u662F\u6230\u5834\u4E2D\u4E0D\u53EF\u6216\u7F3A\u7684\u9632\u8B77\u4E4B\u6CD5\u3002"
    concept: "\u57FA\u790E\u9632\u79A6\u5361\uFF0C\u63D0\u4F9B\u7A69\u5B9A\u8B77\u7532\uFF0C\u78BA\u4FDD\u751F\u5B58\u4E26\u652F\u6490\u9577\u671F\u6230\u9B25\u3002"
  - id: 'Skill_ShenLingBiYou '
    displayName: "\u6CD5\u8853_\u795E\u9748\u4FDD\u4F51"
    icon: {fileID: 21300000, guid: 9c29e4a48be772349b574192e431f7ea, type: 3}
    portrait: {fileID: 21300000, guid: 9c29e4a48be772349b574192e431f7ea, type: 3}
    pinned: 0
    order: 4
    cardSprite: {fileID: 21300000, guid: 9c29e4a48be772349b574192e431f7ea, type: 3}
    areaSprite: {fileID: 21300000, guid: 451d6cb975499b148879f40973398d9d, type: 3}
    intro: "\u53EC\u5F15\u795E\u9748\u4E4B\u529B\u964D\u65BC\u5DF1\u8EAB\uFF0C\u7B26\u5149\u5927\u76DB\uFF0C\u8B77\u9AD4\u4E4B\u6C23\u77AC\u9593\u66B4\u6F32\u3002\u6B64\u8853\u80FD\u5728\u5371\u6025\u6642\u523B\u5927\u5E45\u63D0\u5347\u9632\u8B77\uFF0C\u4F7F\u65BD\u8853\u8005\u514D\u65BC\u91CD\u5275\u3002\u7136\u800C\u795E\u529B\u96E3\u4E45\u5B58\uFF0C\u7B26\u6548\u4E00\u904E\uFF0C\u4FBF\u96A8\u4E4B\u6D88\u6563\u3002"
    concept: "\u5927\u91CF\u8B77\u7532\uFF0B\u6D88\u8017\u578B\u5361\u724C\uFF0C\u7528\u65BC\u95DC\u9375\u9632\u79A6\u8207\u4FDD\u547D\u6642\u6A5F\u3002"
  - id: 'Move_XingMangPoZhen '
    displayName: "\u79FB\u52D5_\u661F\u8292\u7834\u9663"
    icon: {fileID: 21300000, guid: bffba04909347d94983f9a19388ab44f, type: 3}
    portrait: {fileID: 21300000, guid: bffba04909347d94983f9a19388ab44f, type: 3}
    pinned: 0
    order: 5
    cardSprite: {fileID: 21300000, guid: bffba04909347d94983f9a19388ab44f, type: 3}
    areaSprite: {fileID: 21300000, guid: 242b7399e025b6c40b075eb9fcf21324, type: 3}
    intro: "\u501F\u661F\u5149\u4E4B\u52E2\u7A7F\u884C\u6230\u5834\uFF0C\u8EAB\u5F71\u5316\u70BA\u4E00\u9053\u6D41\u5149\u76F4\u7DDA\u7A81\u9032\u3002\u6240\u7D93\u4E4B\u8655\u528D\u6C23\u6A6B\u6383\uFF0C\u6575\u4EBA\u96E3\u4EE5\u963B\u64CB\u3002\u6B64\u8853\u4E0D\u50C5\u80FD\u5FEB\u901F\u4F4D\u79FB\uFF0C\u66F4\u80FD\u5728\u7A81\u7834\u6575\u9663\u7684\u540C\u6642\u9020\u6210\u50B7\u5BB3\u3002"
    concept: "\u76F4\u7DDA\u4F4D\u79FB\uFF0B\u8DEF\u5F91\u653B\u64CA\uFF0C\u517C\u5177\u6A5F\u52D5\u8207\u8F38\u51FA\uFF0C\u5F37\u5316\u6230\u5834\u7A7F\u900F\u80FD\u529B\u3002"
  monstersData:
  - id: HuGuPo
    displayName: "\u864E\u59D1\u5A46"
    icon: {fileID: 21300000, guid: 4180c7217c655d942b1f30fb9db74b74, type: 3}
    portrait: {fileID: 21300000, guid: 4180c7217c655d942b1f30fb9db74b74, type: 3}
    pinned: 0
    order: 0
    intro: "\u864E\u59D1\u5A46\u6F5B\u4F0F\u65BC\u4EBA\u9593\uFF0C\u4EE5\u9577\u8005\u4E4B\u59FF\u63A5\u8FD1\u5B69\u7AE5\uFF0C\u85C9\u6EAB\u67D4\u8A9E\u6C23\u63A9\u84CB\u55DC\u8840\u672C\u6027\u3002\u5979\u719F\u77E5\u4EBA\u6027\u5F31\u9EDE\uFF0C\u5E38\u5728\u591C\u6DF1\u6642\u73FE\u51FA\u539F\u5F62\uFF0C\u541E\u566C\u7375\u7269\u3002\u50B3\u8AAA\u5176\u6E90\u81EA\u864E\u9748\u6210\u7CBE\uFF0C\u64C5\u9577\u507D\u88DD\u8207\u5F15\u8A98\uFF0C\u662F\u6700\u4EE4\u4EBA\u9632\u4E0D\u52DD\u9632\u7684\u5996\u602A\u4E4B\u4E00\u3002"
    tip: "\u300C\u864E\u59D1\u5A46\u6700\u5371\u96AA\u7684\u662F\u7981\u932E\u63A5\u885D\u92D2\uFF0C\u770B\u5230\u7981\u932E\u5F8C\u8981\u63D0\u524D\u6E96\u5099\u89E3\u6CD5\u3002\u300D\r\n\u300C\u885D\u92D2\u9396\u5B9A\u7684\u662F\u4F60\u7576\u4E0B\u7684\u4F4D\u7F6E\uFF0C\u4E0D\u662F\u4E4B\u5F8C\u7684\u65B0\u4F4D\u7F6E\u3002\u300D\r\n\u300C\u5225\u548C\u864E\u59D1\u5A46\u6162\u6162\u63DB\u8840\uFF0C\u5979\u7684\u666E\u653B\u6703\u758A\u6D41\u8840\uFF0C\u62D6\u4E45\u4E86\u5F88\u8667\u3002\u300D"
    skills:
    - icon: {fileID: 21300000, guid: 2f5a611de1cbf4748a795a574c7643c9, type: 3}
      skillName: "\u55DC\u8840"
      description: "\uFF08\u88AB\u52D5\uFF09\uFF1A\u653B\u64CA\u73A9\u5BB6\u6642\uFF0C\u4F7F\u73A9\u5BB6\u9032\u5165
        \u6D41\u88402\u56DE\u5408\u3002"
    - icon: {fileID: 21300000, guid: a2f8de43ea9b7fb44a701094237de936, type: 3}
      skillName: "\u7981\u932E"
      description: "\uFF08\u51B7\u537B\uFF1A3\uFF09\uFF1A\u5C0D\u73A9\u5BB6\u65BD\u52A0
        \u7981\u932E3\u56DE\u5408\u3002"
    - icon: {fileID: 21300000, guid: a2f8de43ea9b7fb44a701094237de936, type: 3}
      skillName: "\u885D\u649E\u64CA\u9000"
      description: "\uFF08\u51B7\u537B\uFF1A4\uFF09\uFF1A\u82E5\u73A9\u5BB6\u8655\u65BC\u7981\u932E\uFF0C\u672C\u56DE\u5408\u84C4\u529B\u4E26\u9396\u5B9A\u73A9\u5BB6\u4F4D\u7F6E\uFF08\u9AD8\u4EAE\u63D0\u793A\uFF09\uFF1B\u4E0B\u4E00\u56DE\u5408\u885D\u5411\u9396\u5B9A\u683C\uFF0C\u82E5\u73A9\u5BB6\u4ECD\u5728\u8A72\u683C\uFF0C\u9020\u6210
        15 \u50B7\u5BB3\u4E26\u5C07\u73A9\u5BB6\u649E\u98DB\u52301\u683C\u3002"
  - id: GouShe
    displayName: "\u9264\u86C7"
    icon: {fileID: 21300000, guid: 9b6870ad65902c94dbff69c209a516ec, type: 3}
    portrait: {fileID: 21300000, guid: 9b6870ad65902c94dbff69c209a516ec, type: 3}
    pinned: 0
    order: 0
    intro: "\u9264\u86C7\u68F2\u606F\u65BC\u6FD5\u5730\u8207\u6CB3\u57DF\u4E4B\u4E2D\uFF0C\u5C3E\u7AEF\u5982\u9264\uFF0C\u80FD\u9060\u8DDD\u52FE\u53D6\u7375\u7269\u3002\u7260\u5E38\u6F5B\u4F0F\u6C34\u4E0B\u4F3A\u6A5F\u800C\u52D5\uFF0C\u5229\u7528\u5730\u5F62\u5C01\u9396\u9000\u8DEF\uFF0C\u4F7F\u7375\u7269\u7121\u8655\u53EF\u9003\u3002\u5728\u53F0\u7063\u5996\u602A\u50B3\u8AAA\u4E2D\uFF0C\u88AB\u8996\u70BA\u6C34\u57DF\u4E2D\u7684\u63A0\u98DF\u8005\uFF0C\u8C61\u5FB5\u96B1\u533F\u8207\u81F4\u547D\u4F0F\u64CA\u3002"
    tip: "\u300C\u5225\u8B93\u9264\u86C7\u8E29\u6C34\uFF0C\u6C34\u683C\u4E0D\u53EA\u8B93\u7260\u66F4\u786C\uFF0C\u4E5F\u662F\u7260\u5927\u62DB\u7684\u8D77\u624B\u5F0F\u3002\u300D\r\n\u300C\u9264\u86C7\u6D88\u5931\u6642\uFF0C\u7ACB\u523B\u63DB\u5217\u3002\u4EAE\u8D77\u7684\u4E09\u5217\u6703\u5728\u4E0B\u500B\u6575\u65B9\u56DE\u5408\u843D\u4E0B\u91CD\u64CA\u3002\u300D\r\n\u300C\u5225\u628A\u8840\u91CF\u6293\u592A\u525B\u597D\uFF0C\u9264\u86C7\u7684\u666E\u901A\u653B\u64CA\u6709\u6A5F\u6703\u8FFD\u52A0\u4E00\u53E3\u3002\u300D"
    skills:
    - icon: {fileID: 21300000, guid: 2f5a611de1cbf4748a795a574c7643c9, type: 3}
      skillName: "\u6C34\u57DF\u74B0\u7E5E"
      description: "\uFF08\u958B\u5834\uFF09\uFF1A\u6230\u9B25\u958B\u59CB\u6642\uFF0C\u96A8\u6A5F\u751F\u62103\u7D44\u6C34\u5143\u7D20\u5340\u57DF\uFF08\u4E2D\u5FC3\u683C\uFF0B\u5468\u570D\u683C\uFF09\u3002"
    - icon: {fileID: 21300000, guid: 2f5a611de1cbf4748a795a574c7643c9, type: 3}
      skillName: "\u6C34\u7532"
      description: "\uFF08\u88AB\u52D5\uFF09\uFF1A\u7AD9\u5728\u6C34\u683C\u6642\uFF0C\u5996\u602A\u56DE\u5408\u7D50\u675F\u6642\u81EA\u52D5\u7372\u5F97+10\u8B77\u7532\u3002"
    - icon: {fileID: 21300000, guid: 2f5a611de1cbf4748a795a574c7643c9, type: 3}
      skillName: "\u96D9\u64CA"
      description: "\uFF08\u88AB\u52D5\uFF09\uFF1A\u666E\u901A\u653B\u64CA\u6642\u6709
        50% \u6A5F\u7387\u8FFD\u52A0\u4E00\u6B21 30% \u50B7\u5BB3\u3002 \r"
    - icon: {fileID: 21300000, guid: 2f5a611de1cbf4748a795a574c7643c9, type: 3}
      skillName: "\u6F5B\u6C34\u7A81\u8972"
      description: "\uFF08\u51B7\u537B\uFF1A2\uFF09\uFF1A\u5728\u6C34\u683C\u6642\u66AB\u6642\u6D88\u5931\uFF0C\u9396\u5B9A\u73A9\u5BB6\u6240\u5728\u76F4\u7DDA\u4E26\u9AD8\u4EAE\u9810\u653B\u64CA\u683C\uFF1B\u4E0B\u4E00\u56DE\u5408\u5C0D\u9396\u5B9A\u683C\u653B\u64CA\u3002\u82E5\u73A9\u5BB6\u4ECD\u5728\u9396\u5B9A\u683C\uFF0C\u53D7\u523010\u50B7\u5BB3\uFF0B\u865B\u5F312\u56DE\u5408\u3002\u4E4B\u5F8C\u5F9E\u6700\u9760\u8FD1\u73A9\u5BB6\u7684\u6C34\u683C\u91CD\u65B0\u51FA\u73FE\u3002"
  - id: StonToad
    displayName: "\u77F3\u87FE\u870D"
    icon: {fileID: 21300000, guid: 5536f9f65000bb047adb52eb0c94e708, type: 3}
    portrait: {fileID: 21300000, guid: 5536f9f65000bb047adb52eb0c94e708, type: 3}
    pinned: 0
    order: 0
    intro: "\u77F3\u87FE\u870D\u591A\u898B\u65BC\u5C71\u6797\u6216\u53E4\u5EDF\u9644\u8FD1\uFF0C\u5916\u5F62\u5982\u77F3\u537B\u860A\u542B\u5996\u6C23\u3002\u50B3\u8AAA\u7260\u5438\u6536\u5730\u6C23\u6210\u5F62\uFF0C\u64C1\u6709\u5805\u786C\u8EAB\u8EC0\u8207\u8A6D\u7570\u6BD2\u6027\uFF0C\u5E38\u975C\u4F0F\u4E0D\u52D5\u5F15\u8A98\u7375\u7269\u9760\u8FD1\u3002\u4E00\u65E6\u9A5A\u52D5\uFF0C\u4FBF\u4EE5\u7DE9\u6162\u537B\u81F4\u547D\u7684\u65B9\u5F0F\u541E\u566C\u6575\u4EBA\uFF0C\u96E3\u4EE5\u5C0D\u4ED8\u3002"
    tip: "\u300C\u5225\u7528\u5C0F\u50B7\u5BB3\u9935\u7260\u8B77\u7532\uFF0C\u7B49\u7206\u767C\u56DE\u5408\u518D\u51FA\u624B\u3002\u300D\r\n\u300C\u77F3\u87FE\u870D\u7684\u8B77\u7532\u5C31\u662F\u7260\u7684\u653B\u64CA\u529B\uFF0C\u62D6\u8D8A\u4E45\u8D8A\u5371\u96AA\u3002\u300D\r\n\u300C\u80FD\u9060\u653B\u5C31\u5225\u8CBC\u8EAB\uFF0C\u5148\u7834\u7532\u518D\u6536\u982D\u3002\u300D "
    skills:
    - icon: {fileID: 21300000, guid: 14fe031f08c013540a92eadae16d9de3, type: 3}
      skillName: "\u56FA\u82E5\u91D1\u6E6F"
      description: "\uFF08\u88AB\u52D5\uFF09\uFF1A\u8B77\u7532\u4E0D\u6703\u56E0\u70BA\u7D50\u675F\u56DE\u5408\u800C\u5237\u65B0(\u8B77\u7532\u4E0A\u9650\uFF1A16)"
