  monstersData:
  - id: HuGuPo
    displayName: "\u864E\u59D1\u5A46"
    icon: {fileID: 21300000, guid: b9c47c8fcbd195043b2f47aa261a49c8, type: 3}
    portrait: {fileID: 21300000, guid: b9c47c8fcbd195043b2f47aa261a49c8, type: 3}
    pinned: 0
    order: 0
    intro: "\u50B3\u8AAA\u4E2D\u6703\u507D\u88DD\u6210\u6148\u7965\u8001\u4EBA\u7684\u5996\u602A\uFF0C\u5BE6\u969B\u4E0A\u537B\u662F\u4EE5\u4EBA\u985E\u70BA\u98DF\u7684\u864E\u5996\u3002\n\u864E\u59D1\u5A46\u64C5\u9577\u5229\u7528\u8A5B\u5492\u9650\u5236\u7375\u7269\u7684\u884C\u52D5\uFF0C\u518D\u4EE5\u731B\u70C8\u7684\u885D\u649E\u5C07\u76EE\u6A19\u64CA\u98DB\u3002\n\u82E5\u88AB\u5979\u76EF\u4E0A\uFF0C\u9003\u8DD1\u5F80\u5F80\u5DF2\u7D93\u592A\u665A\u3002"
    tip: "\u864E\u59D1\u5A46\u6703\u5148\u8B93\u73A9\u5BB6\u9677\u5165\u7981\u932E\uFF0C\u518D\u6E96\u5099\u5F37\u529B\u885D\u649E\u3002\r\n\u82E5\u770B\u5230\u5979\u958B\u59CB\u84C4\u529B\u4E26\u9396\u5B9A\u4F4D\u7F6E\uFF0C\u6700\u597D\u63D0\u524D\u96E2\u958B\u8A72\u683C\u3002"
    skills:
    - icon: {fileID: 21300000, guid: 185fcb8d652741645a212553470b6897, type: 3}
      skillName: "\u7981\u932E\u8A5B\u5492"
      description: "\u5C0D\u73A9\u5BB6\u65BD\u52A0\u7981\u932E\u6548\u679C2\u56DE\u5408\uFF0C\u4F7F\u73A9\u5BB6\u7121\u6CD5\u79FB\u52D5\u3002\n\u51B7\u537B\u6642\u9593\uFF1A3\u56DE\u5408\u3002"
    - icon: {fileID: 21300000, guid: 31473bef10837b34c8e439b101e60e54, type: 3}
      skillName: "\u731B\u649E\u7A81\u8972"
      description: "\u7576\u73A9\u5BB6\u8655\u65BC\u7981\u932E\u72C0\u614B\u6642\uFF0C\u864E\u59D1\u5A46\u6703\u84C4\u529B1\u56DE\u5408\u4E26\u9396\u5B9A\u73A9\u5BB6\u4F4D\u7F6E\u3002\n\u4E0B\u4E00\u56DE\u5408\u885D\u5411\u9396\u5B9A\u683C\u5B50\uFF0C\u82E5\u73A9\u5BB6\u4ECD\u5728\u8A72\u4F4D\u7F6E\uFF0C\u5C07\u88AB\u649E\u98DB\u4E00\u683C\u4E26\u53D7\u523015\u9EDE\u50B7\u5BB3\u3002\n\u51B7\u537B\u6642\u9593\uFF1A4\u56DE\u5408\u3002"
