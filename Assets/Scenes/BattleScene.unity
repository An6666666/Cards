    rightIcon: {fileID: 21300000, guid: d20f63563e2c9d3488943200bdd60050, type: 3}
    combinationText: "\u706B + \u51B0"
    titleText: "\u878D\u5316"
    descriptionText: "\u706B+\u51B0\u7684\u878D\u5316\u53CD\u61C9\uFF0C\u6703\u8B93\u5F8C\u8005\u4F7F\u7528\u7684\u50B7\u5BB3\u589E\u52A01.5\u500D\uFF0C\u88AB\u653B\u64CA\u7684\u5996\u602A\u6703\u7559\u4E0B\u5F8C\u8005\u7684\u5143\u7D20\u3002"
