    rightIcon: {fileID: 21300000, guid: bfeec5098db764d4e843c89c8fae2567, type: 3}
    combinationText: "\u6C34 + \u6728"
    titleText: "\u751F\u9577"
    descriptionText: "\u751F\u9577\u53CD\u61C9\u6703\u5728\u68CB\u76E4\u4E0A\u751F\u9577\u51FA\u834A\u68D8\uFF0C\u834A\u68D8\u6703\u5728\u73A9\u5BB6\u7D50\u675F\u56DE\u5408\u6642\uFF0C\u653B\u64CA\u5728\u834A\u68D8\u683C\u4E0A\u7684\u5996\u602A\u9020\u62103\u9EDE\u50B7\u5BB3\u3002"
