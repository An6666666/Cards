    combinationText: "\u6C34 + \u96F7"
    titleText: "\u5C0E\u96FB"
    descriptionText: "\u6C34+\u96F7\u7684\u5C0E\u96FB\u53CD\u61C9\uFF0C\u6703\u6CBF\u8457\u76F8\u9023\u7684\u6C34\u5730\u677F\u8207\u5E36\u6709\u6C34\u5143\u7D20\u7684\u5996\u602A\u50B3\u5C0E\uFF0C\u5C0D\u5176\u4ED6\u76EE\u6A19\u9020\u62100.5\u500D\u50B7\u5BB3\uFF0C\u4E26\u7559\u4E0B\u5F8C\u8005\u7684\u5143\u7D20\u3002"
