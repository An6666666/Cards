  - id: Fire_Wood
    primaryElementId: Fire
    secondaryElementId: Wood
    leftIcon: {fileID: 21300000, guid: 4fb3c68d1b0904e40ac2040535555abe, type: 3}
    rightIcon: {fileID: 21300000, guid: bfeec5098db764d4e843c89c8fae2567, type: 3}
    combinationText: "\u706B + \u6728"
    titleText: "\u71C3\u71D2"
    descriptionText: "\u706B+\u6728\u6703\u7522\u751F\u71C3\u71D2\u7684\u6548\u679C\uFF0C\u6703\u6B98\u7559\u706B\u5143\u7D20\uFF0C\u71C3\u71D2\u6301\u7E8C5\u56DE\u5408\uFF0C\u6BCF\u6B21\u9020\u62103\u9EDE\u50B7\u5BB3\u3002"
