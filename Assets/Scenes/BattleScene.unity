    secondaryElementId: Thunder
    leftIcon: {fileID: 21300000, guid: 4fb3c68d1b0904e40ac2040535555abe, type: 3}
    rightIcon: {fileID: 21300000, guid: 5dae7914913eec541aa1f3a47e938c3d, type: 3}
    combinationText: "\u706B + \u96F7"
    titleText: "\u8D85\u8F09"
    descriptionText: "\u8D85\u8F09\u6703\u5C0D\u88AB\u653B\u64CA\u7684\u5996\u602A\u5468\u570D\u7684\u6575\u4EBA\uFF0C\u4E5F\u9020\u62100.5\u500D\u7684\u50B7\u5BB3\uFF0C\u88AB\u653B\u64CA\u7684\u5996\u602A\u6703\u7559\u4E0B\u5F8C\u8005\u7684\u5143\u7D20\u3002"
