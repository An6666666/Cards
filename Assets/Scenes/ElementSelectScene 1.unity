--- !u!114 &96605113
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 96605111}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2c1d6dd52c256114185a72608d20b571, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  selectionUI: {fileID: 596144955}
  dialogueBubbleUI: {fileID: 0}
  npcPresenter: {fileID: 0}
  dialogueDatabase: {fileID: 0}
  introKey: 
  introLines:
  - "\u9996\u6B21\u7684\u4FEE\u884C\u8981\u958B\u59CB\u4E86\uFF0C\u5C0F\u9053\u58EB"
  - "\u9019\u88E1\u662F\u4F60\u9078\u64C7\u521D\u59CB\u653B\u64CA\u7B26\u5492\u5143\u7D20\u7684\u5730\u65B9\u3002\u9EDE\u64CA\u756B\u9762\u4E0A\u7684\u5143\u7D20\u4F86\u9078\u64C7\u521D\u59CB\u653B\u64CA\u7B26\u5492\u5143\u7D20\u3002"
  - "\u5E73\u5E38\u4EFB\u52D9\u6642\uFF0C\u4F60\u53EA\u80FD\u9078\u64C7\u5169\u7A2E\u5143\u7D20\u540C\u884C\u3002\u4F46\u9019\u662F\u4F60\u7B2C\u4E00\u6B21\u7684\u4EFB\u52D9\uFF0C\u4F60\u53EF\u4EE5\u9010\u4E00\u5617\u8A66\u6240\u6709\u5143\u7D20\u3002"
  - "\u706B\u3001\u6C34\u3001\u51B0\u3001\u96F7\u3001\u6728\uFF0C\u4E0D\u53EA\u6703\u9644\u8457\u5728\u5996\u7269\u8EAB\u4E0A\uFF0C\u6709\u4E9B\u5143\u7D20\uFF0C\u751A\u81F3\u6703\u9644\u8457\u5728\u5730\u9762\u4E4B\u4E0A\u3002"
  - "\u7576\u5996\u7269\u8EAB\u4E0A\u5DF2\u7D93\u6709\u9644\u8457\u5143\u7D20\u6642\uFF0C\u4F60\u518D\u65BD\u52A0\u53E6\u4E00\u7A2E\u5143\u7D20\uFF0C\u4FBF\u6703\u5F15\u767C\u5143\u7D20\u53CD\u61C9\u2014\u2014\u6709\u7684\u6703\u8B93\u50B7\u5BB3\u589E\u5E45\uFF0C\u6709\u7684\u6703\u5411\u56DB\u5468\u64F4\u6563\uFF0C\u6709\u7684\u80FD\u51CD\u4F4F\u5996\u7269\uFF0C\u6709\u7684\u5247\u6703\u4EE4\u4E0B\u4E00\u64CA\u5A01\u529B\u500D\u589E\u3002"
  - "\u53BB\u5427\uFF0C\u9EDE\u9078\u756B\u9762\u4E0A\u7684\u5143\u7D20\u3002\u6BCF\u7576\u4F60\u505A\u51FA\u9078\u64C7\uFF0C\u6211\u90FD\u6703\u70BA\u4F60\u8B1B\u89E3\u5B83\u7684\u529B\u91CF\u3002"
  elementDialogues:
  - element: 0
    lines:
    - "\u706B\uFF0C\u8C61\u5FB5\u711A\u6EC5\u8207\u7206\u767C\u3002\n\u706B\u7B26\u6703\u5728\u5996\u7269\u8EAB\u4E0A\u7559\u4E0B\u707C\u71B1\u7684\u5370\u8A18\u3002"
    - "\u82E5\u5996\u7269\u8EAB\u4E0A\u5DF2\u6709\u6C34\u6216\u51B0\uFF0C\u706B\u6703\u77AC\u9593\u5F15\u7206\uFF0C\u4F7F\u50B7\u5BB3\u5927\u5E45\u63D0\u5347\u3002"
    - "\u82E5\u706B\u9047\u4E0A\u6728\uFF0C\u5247\u6703\u5F15\u71C3\u5176\u8EAB\uFF0C\u8B93\u5996\u7269\u5728\u6578\u56DE\u5408\u5167\u6301\u7E8C\u53D7\u50B7\u3002"
    - "\u82E5\u706B\u8207\u96F7\u76F8\u649E\uFF0C\u5176\u529B\u91CF\u5C07\u5411\u56DB\u5468\u64F4\u6563\uFF0C\u9023\u9644\u8FD1\u7684\u5996\u7269\u4E5F\u7121\u6CD5\u5016\u514D\u3002"
    dialogueKey: 
  - element: 1
    lines:
    - "\u6C34\uFF0C\u8C61\u5FB5\u6D41\u52D5\u8207\u50B3\u5C0E\u3002\n\u6C34\u7B26\u4E0D\u53EA\u6703\u9644\u8457\u5728\u5996\u7269\u8EAB\u4E0A\uFF0C\u9084\u6703\u9644\u8457\u5728\u5730\u9762\uFF0C\u4E26\u5411\u5468\u570D\u8513\u5EF6\u3002"
    - "\u82E5\u6C34\u9047\u4E0A\u706B\uFF0C\u6703\u5F15\u767C\u5287\u70C8\u53CD\u61C9\uFF0C\u4F7F\u50B7\u5BB3\u63D0\u5347\u3002"
    - "\u82E5\u6C34\u8207\u96F7\u7D50\u5408\uFF0C\u96F7\u96FB\u4FBF\u6703\u6CBF\u8457\u6C34\u8108\u50B3\u5C0E\uFF0C\u540C\u6642\u6253\u64CA\u591A\u540D\u6575\u4EBA\u3002"
    - "\u82E5\u6C34\u78B0\u4E0A\u51B0\uFF0C\u5247\u53EF\u80FD\u5C07\u5996\u7269\u51CD\u7D50\uFF0C\u4F7F\u5176\u7121\u6CD5\u884C\u52D5\u4E00\u56DE\u5408\u3002"
    dialogueKey: 
  - element: 3
    lines:
    - "\u51B0\uFF0C\u8C61\u5FB5\u5C01\u9396\u8207\u63A7\u5236\u3002\n\u51B0\u7B26\u6703\u5728\u5996\u7269\u8EAB\u4E0A\u7559\u4E0B\u5BD2\u971C\u3002"
    - "\u82E5\u51B0\u8207\u6C34\u76F8\u9047\uFF0C\u4FBF\u53EF\u80FD\u5C07\u5996\u7269\u51CD\u7D50\uFF0C\u4EE4\u5176\u4E00\u56DE\u5408\u7121\u6CD5\u884C\u52D5\u3002"
    - "\u82E5\u51B0\u906D\u9047\u96F7\uFF0C\u5247\u6703\u5F62\u6210\u300C\u8D85\u5C0E\u300D\uFF0C\u4F7F\u4E0B\u4E00\u6B21\u50B7\u5BB3\u66F4\u52A0\u81F4\u547D\u3002"
    dialogueKey: 
  - element: 2
    lines:
    - "\u96F7\uFF0C\u8C61\u5FB5\u77AC\u64CA\u8207\u50B3\u905E\u3002\n\u96F7\u7B26\u7684\u529B\u91CF\uFF0C\u4E0D\u53EA\u843D\u5728\u4E00\u500B\u6575\u4EBA\u8EAB\u4E0A\u3002"
    - "\u82E5\u96F7\u64CA\u4E2D\u5E36\u6C34\u7684\u5996\u7269\uFF0C\u6216\u843D\u5728\u6F6E\u6FD5\u7684\u5730\u9762\u4E0A\uFF0C\u96F7\u96FB\u4FBF\u6703\u6CBF\u8457\u6C34\u8108\u50B3\u5C0E\uFF0C\u540C\u6642\u547D\u4E2D\u591A\u500B\u6575\u4EBA\u3002"
    - "\u82E5\u96F7\u8207\u6728\u7D50\u5408\uFF0C\u5247\u6703\u5F15\u767C\u96F7\u64CA\u5370\u8A18\uFF0C\u8B93\u4E0B\u4E00\u6B21\u653B\u64CA\u5A01\u529B\u500D\u589E\u3002"
    - "\u82E5\u96F7\u8207\u51B0\u7D50\u5408\uFF0C\u5247\u6703\u524A\u5F31\u5996\u602A\uFF0C\u8B93\u4E0B\u4E00\u6B21\u50B7\u5BB3\u66F4\u52A0\u731B\u70C8\u3002"
    dialogueKey: 
  - element: 4
    lines:
    - "\u6728\uFF0C\u8C61\u5FB5\u8513\u5EF6\u8207\u5B55\u80B2\u3002\n\u6728\u7B26\u6703\u5728\u5996\u7269\u8207\u5730\u9762\u4E0A\u7559\u4E0B\u751F\u9577\u7684\u5370\u8A18\uFF0C\n\u4E26\u5411\u56DB\u5468\u64F4\u6563\u3002"
    - "\u82E5\u6728\u9047\u4E0A\u706B\uFF0C\u4FBF\u6703\u88AB\u5F15\u71C3\uFF0C\u8B93\u5996\u7269\u5728\u591A\u500B\u56DE\u5408\u4E2D\u6301\u7E8C\u53D7\u5275\u3002"
    - "\u82E5\u6728\u8207\u96F7\u7D50\u5408\uFF0C\u5247\u6703\u5F15\u767C\u96F7\u64CA\u72C0\u614B\uFF0C\u4F7F\u4E0B\u4E00\u6B21\u653B\u64CA\u5A01\u529B\u500D\u589E\u3002"
    dialogueKey: 
