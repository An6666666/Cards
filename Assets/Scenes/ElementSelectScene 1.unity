  startDisabledColor: {r: 0.5, g: 0.5, b: 0.5, a: 1}
  leftInfoText: {fileID: 371713318}
  elementInfoTable:
  - element: 1
    description: "\u7D66\u4E88\u6575\u4EBA\u6C34\u5C6C\u6027\u50B7\u5BB3\uFF0C\u4E26\u7D66\u4E88\u8A72\u6575\u4EBA\u8207\u5176\u6240\u5728\u8207\u76F8\u9130\u683C\u5B50\u3010\u6C34\u3011\u6A19\u7C64\u3002"
  - element: 0
    description: "\u7D66\u4E88\u6575\u4EBA\u706B\u5C6C\u6027\u50B7\u5BB3\uFF0C\u7D66\u4E88\u3010\u706B\u3011\u6A19\u7C64\u3002"
  - element: 4
    description: "\u7D66\u4E88\u6575\u4EBA\u6728\u5C6C\u6027\u50B7\u5BB3\uFF0C\u4E26\u7D66\u4E88\u8A72\u6575\u4EBA\u53CA\u5176\u6240\u5728\u8207\u76F8\u9130\u683C\u5B50\u3010\u6728\u3011\u6A19\u7C64\u3002"
  - element: 3
    description: "\u7D66\u4E88\u6575\u4EBA\u51B0\u5C6C\u6027\u50B7\u5BB3\uFF0C\u4E26\u7D66\u8A72\u6575\u4EBA\u53CA\u5176\u76F8\u9130\u6575\u4EBA\u9644\u4E0A\u3010\u51B0\u3011\u6A19\u7C64\u3002"
  - element: 2
    description: "\u7D66\u4E88\u6575\u4EBA\u96F7\u5C6C\u6027\u50B7\u5BB3\uFF0C\u4E26\u7D66\u4E88\u3010\u96F7\u3011\u6A19\u7C64\u3002"
  reactionInfoTable:
  - a: 0
    b: 1
    title: "\u84B8\u767C"
    description: "\u706B+\u6C34\u7684\u84B8\u767C\u53CD\u61C9\uFF0C\u6703\u8B93\u5F8C\u8005\u4F7F\u7528\u7684\u50B7\u5BB3\u63D0\u5347\u70BA
      1.5 \u500D\uFF0C\u4E26\u7559\u4E0B\u5F8C\u624B\u653B\u64CA\u7684\u5143\u7D20\u3002"
  - a: 1
    b: 2
    title: "\u5C0E\u96FB"
    description: "\u96F7\u64CA\u4E2D\u5E36\u6709\u3010\u6C34\u3011\u7684\u76EE\u6A19\u6642\u89F8\u767C\u5C0E\u96FB\uFF0C\u50B7\u5BB3\u6703\u4EE5
      BFS \u65B9\u5F0F\u6CBF\u8457\u6C34\u5730\u683C\u8207\u6C34\u6A19\u7C64\u9023\u9396\u50B3\u905E\u3002\u53CD\u61C9\u5F8C\u6B98\u7559\u3010\u96F7\u3011\u5143\u7D20\u3002"
  - a: 0
    b: 2
    title: "\u8D85\u8F09"
    description: "\u706B\u8207\u96F7\u76F8\u9047\u6642\u89F8\u767C\u8D85\u8F09\uFF0C\u5C0D\u76EE\u6A19\u9644\u8FD1\u9020\u6210
      0.5 \u500D\u7684\u5C0F\u7BC4\u570D\u7206\u70B8\u50B7\u5BB3\u3002\u53CD\u61C9\u5F8C\u6B98\u7559\u3010\u706B\u3011\u5143\u7D20\u3002"
  - a: 1
    b: 4
    title: "\u751F\u9577"
    description: "\u751F\u9577\u53CD\u61C9\u6703\u5728\u68CB\u76E4\u4E0A\u751F\u9577\u51FA\u834A\u68D8\u3002\u834A\u68D8\u6703\u5728\u73A9\u5BB6\u7D50\u675F\u56DE\u5408\u6642\uFF0C\u5C0D\u7AD9\u5728\u834A\u68D8\u683C\u4E0A\u7684\u5996\u602A\u9020\u6210
      3 \u9EDE\u50B7\u5BB3\u3002"
  - a: 1
    b: 3
    title: "\u51B0\u51CD"
    description: "\u51B0+\u6C34\u7684\u51B0\u51CD\u53CD\u61C9\uFF0C\u53EF\u4EE5\u51B0\u51CD\u5996\u602A\uFF0C\u8B93\u5176\u7121\u6CD5\u79FB\u52D5\u8207\u653B\u64CA\u3002"
  - a: 0
    b: 4
    title: "\u71C3\u71D2"
    description: "\u6728\u9047\u706B\u6703\u88AB\u9EDE\u71C3\uFF0C\u8B93\u76EE\u6A19\u9032\u5165
      5 \u56DE\u5408\u7684\u71C3\u71D2\u72C0\u614B\u3002\u53CD\u61C9\u5F8C\u6B98\u7559\u3010\u706B\u3011\u5143\u7D20\u3002"
  - a: 0
    b: 3
    title: "\u878D\u5316"
    description: "\u706B\u8207\u51B0\u76F8\u9047\u6642\u89F8\u767C\u878D\u5316\uFF0C\u9020\u62101.5\u500D\u50B7\u5BB3\u3002\u53CD\u61C9\u5F8C\u6B98\u7559\u3010\u706B\u3011\u5143\u7D20\u3002"
  - a: 4
    b: 2
    title: "\u96F7\u64CA"
    description: "\u96F7+\u6728\u7684\u96F7\u64CA\u53CD\u61C9\uFF0C\u6703\u8B93\u63A5\u4E0B\u4F86\u9020\u6210\u7684\u50B7\u5BB3\u8B8A\u6210
      2 \u500D\u3002"
  - a: 0
    b: 3
    title: "\u8D85\u5C0E"
    description: "\u51B0\u8207\u96F7\u76F8\u9047\u6642\u89F8\u767C\u8D85\u5C0E\uFF0C\u4F7F\u76EE\u6A19\u4E0B\u4E00\u6B21\u53D7\u5230\u7684\u653B\u64CA\u984D\u5916
      +6 \u50B7\u5BB3\u3002\u53CD\u61C9\u5F8C\u3010\u51B0\u3011\u8207\u3010\u96F7\u3011\u90FD\u6703\u88AB\u6E05\u9664\u3002"
  - a: 3
    b: 4
    title: "\u7D50\u971C"
    description: "\u51B0\u8207\u6728\u76F8\u9047\u6642\u89F8\u767C\u7D50\u971C\uFF0C\u8B93\u76EE\u6A19\u7372\u5F97
      1 \u5C64\u7D50\u971C\u3002\u53CD\u61C9\u5F8C\u3010\u51B0\u3011\u8207\u3010\u6728\u3011\u90FD\u6703\u88AB\u6E05\u9664\u3002"
