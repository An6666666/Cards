    + \u5468\u570D\u76F8\u9130\u683C\u300D\uFF0C\u5728\u73A9\u5BB6\u7D50\u675F\u56DE\u5408\u6642\uFF0C\u5C0D\u5728\u6B64\u7634\u6C23\u683C\u7684\u73A9\u5BB6\u9020\u62105\u9EDE\u50B7\u5BB3\u3002\r\n\u77F3\u93A7\uFF1A\u5996\u602A\u56DE\u5408\u7D50\u675F\u6642\uFF0C\u589E\u52A04\u9EDE\u8B77\u7532\u3002\r\n\u4E09\u5217\u8F5F\u70B8(\u51B7\u537B\uFF1A3)\uFF1A\u6A19\u51FA\u300C\u73A9\u5BB6\u6240\u5728\u5217
    + \u4E0A\u4E0B\u76F8\u9130\u5217\u300D\u5171\u4E09\u5217\uFF0C\u7136\u5F8C\u81EA\u5DF1\u66AB\u6642\u6D88\u5931\uFF1B\u5230\u4E0B\u4E00\u6B21\u7260\u884C\u52D5\u6642\uFF0C\u5982\u679C\u73A9\u5BB6\u9084\u5728\u6A19\u8A18\u5217\u5167\uFF0C\u5C31\u6703\u5403
    15 \u50B7\u5BB3\uFF0C\u4E4B\u5F8C\u9E1A\u54E5\u6703\u96A8\u6A5F\u843D\u56DE\u5834\u4E0A\u3002\r\n\u88AB\u52D5\u6280\u80FD\uFF1A\r\n\u56FA\u82E5\u91D1\u6E6F\uFF1A\u8B77\u7532\u4E0D\u6703\u56E0\u70BA\u7D50\u675F\u56DE\u5408\u800C\u5237\u65B0\u3002\r\n\u501F\u77F3\u9084\u9B42\uFF1A\u9E1A\u54E5\u9032\u5165\u77F3\u5316\u72C0\u614B\uFF0C\u7B49\u5F85
    2 \u500B\u5996\u602A\u56DE\u5408\u5FA9\u6D3B\u9032\u5165\u7B2C\u4E8C\u968E\u6BB5"
