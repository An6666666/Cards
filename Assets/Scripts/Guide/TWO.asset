  m_Script: {fileID: 11500000, guid: 834251c155ce3c94d88d10222b19517d, type: 3}
  m_Name: TWO
  m_EditorClassIdentifier: 
  entries:
  - key: FR
    lines:
    - "\u6211\u6703\u6559\u5C0E\u4F60\u6240\u6709\u7684\u5143\u7D20\u53CD\u61C9\uFF0C\u958B\u59CB\u5427"
    - "\u9019\u662F\u6025\u6025\u5982\u5F8B\u4EE4\u706B\u548C\u6025\u6025\u5982\u5F8B\u4EE4\u6728\uFF0C\u8A66\u8A66\u5427\uFF0C\u6258\u62FD\u5230\u5996\u602A\u8EAB\u4E0A\u4F7F\u7528"
  - key: Burn
    lines:
    - "\u6ED1\u9F20\u79FB\u81F3\u53D7\u5230\u653B\u64CA\u7684\u5996\u602A\u4E0A\uFF0C\u53EF\u4EE5\u770B\u5230\u5996\u602A\u7684\u72C0\u614B"
    - "\u706B+\u6728\u6703\u7522\u751F\u71C3\u71D2\u7684\u6548\u679C\uFF0C\u6703\u6B98\u7559\u706B\u5143\u7D20\uFF0C\u71C3\u71D2\u6301\u7E8C5\u56DE\u5408\uFF0C\u6BCF\u6B21\u9020\u62102\u9EDE\u50B7\u5BB3"
    - "\u5996\u602A\u5728\u71C3\u71D2\u72C0\u614B\u4E0B\uFF0C\u53D7\u5230\u6C34\u5143\u7D20\u6216\u51B0\u5143\u7D20\u50B7\u5BB3\uFF0C\u6703\u56E0\u6B64\u88AB\u6D88\u9664\uFF0C\u8A66\u8A66\u5427"
  - key: Burntwo
    lines:
    - "\u6ED1\u9F20\u79FB\u81F3\u53D7\u5230\u653B\u64CA\u7684\u5996\u602A\u4E0A\u770B\u770B\uFF0C\u71C3\u71D2\u5DF2\u7D93\u88AB\u79FB\u9664\u4E86\uFF0C\u5996\u602A\u751F\u4E0A\u5247\u6703\u53EA\u4FDD\u7559\u6C34\u5143\u7D20"
    - "\u505A\u7684\u597D\uFF0C\u63A5\u4E0B\u4F86\u662F\u84B8\u767C\u53CD\u61C9"
    - "\u9019\u662F\u6025\u6025\u5982\u5F8B\u4EE4\u706B\u548C\u6025\u6025\u5982\u5F8B\u4EE4\u6C34\uFF0C\u8A66\u8A66\u5427\uFF0C\u6258\u62FD\u5230\u5996\u602A\u8EAB\u4E0A\u4F7F\u7528"
  - key: Evaporation
    lines:
    - "\u706B+\u6C34\u7684\u84B8\u767C\u53CD\u61C9\uFF0C\u6703\u8B93\u5F8C\u8005\u4F7F\u7528\u7684\u50B7\u5BB3\u589E\u52A01.5\u500D"
    - "\u4E26\u7559\u4E0B\u5F8C\u8005\u653B\u64CA\u7684\u5143\u7D20"
    - "\u63A5\u4E0B\u4F86\u662F\u96F7\u7206\u53CD\u61C9"
    - "\u9019\u662F\u6025\u6025\u5982\u5F8B\u4EE4\u96F7\u3001\u6025\u6025\u5982\u5F8B\u4EE4\u706B"
  - key: Thunderclap
    lines:
    - "\u96F7\u7206\u6703\u5C0D\u88AB\u653B\u64CA\u7684\u5996\u602A\u5468\u570D\u7684\u6575\u4EBA\uFF0C\u4E5F\u9020\u62100.5\u500D\u7684\u50B7\u5BB3"
    - "\u88AB\u653B\u64CA\u7684\u5996\u602A\u6703\u7559\u4E0B\u5F8C\u8005\u7684\u5143\u7D20"
    - "\u63A5\u4E0B\u4F86\u662F\u751F\u9577\u53CD\u61C9"
  - key: Growth
    lines:
    - "\u751F\u9577\u53CD\u61C9\u6703\u5728\u68CB\u76E4\u4E0A\u751F\u9577\u51FA\u834A\u68D8"
    - "\u834A\u68D8\u6703\u5728\u73A9\u5BB6\u7D50\u675F\u56DE\u5408\u6642\uFF0C\u653B\u64CA\u5728\u834A\u68D8\u683C\u4E0A\u7684\u5996\u602A\u9020\u62103\u9EDE\u50B7\u5BB3"
    - "\u63A5\u4E0B\u4F86\u662F\u5C0E\u96FB\u53CD\u61C9"
    - "\u5148\u4F7F\u7528\u6025\u6025\u5982\u5F8B\u4EE4\u6C34\uFF0C\u5728\u4F7F\u7528\u6025\u6025\u5982\u5F8B\u4EE4\u96F7"
  - key: Conductive
    lines:
    - "\u5148\u4F7F\u7528\u6C34\u5143\u7D20\u7684\u7279\u6027\u8B93\u92EA\u8A2D\u597D\u74B0\u5883\uFF0C\u518D\u7528\u96F7\u5143\u7D20\u9020\u6210\u5C0E\u96FB\u7684\u53CD\u61C9"
  - key: Miss
    lines:
    - "\u4F7F\u7528\u7684\u9806\u5E8F\u932F\u4E86\uFF0C\u518D\u4F7F\u7528\u4E00\u6B21\uFF0C\u5148\u4F7F\u7528\u6025\u6025\u5982\u5F8B\u4EE4\u6C34\uFF0C\u5728\u4F7F\u7528\u6025\u6025\u5982\u5F8B\u4EE4\u96F7"
  - key: Mis
    lines:
    - "\u6025\u6025\u5982\u5F8B\u4EE4\u96F7\u548C\u6025\u6025\u5982\u5F8B\u4EE4\u706B\u9700\u8981\u653B\u64CA\u540C\u4E00\u500B\u5996\u602A\uFF0C\u624D\u80FD\u6B63\u78BA\u7684\u89F8\u767C\u5143\u7D20\u53CD\u61C9"
