%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 834251c155ce3c94d88d10222b19517d, type: 3}
  m_Name: ONE
  m_EditorClassIdentifier: 
  entries:
  - key: Star_one
    lines:
    - "\u5C0F\u9053\u58EB\uFF0C\u9019\u88E1\u662F\u4F60\u7684\u4FEE\u884C\u8DEF\u5F91\u3002\r\n\u6BCF\u4E00\u5C64\u7684\u9078\u64C7\uFF0C\u90FD\u6703\u5F71\u97FF\u4F60\u63A5\u4E0B\u4F86\u7684\u547D\u904B\u3002\r"
  - key: Run_Enter_Battle
    lines:
    - "\u524D\u65B9\u6709\u6575\u3002\r\n\u8A18\u4F4F\uFF0C\u7B26\u5492\u8207\u5143\u7D20\u7684\u642D\u914D\uFF0C\u80FD\u8B93\u6230\u9B25\u4E8B\u534A\u529F\u500D\u3002\r"
  - key: 'Run_Complete_Battle '
    lines:
    - "\u4E0D\u932F\uFF0C\u57FA\u790E\u6230\u9B25\u4F60\u5DF2\u7D93\u638C\u63E1\u4E86\u3002\r\n\u771F\u6B63\u7684\u8003\u9A57\uFF0C\u624D\u6B63\u8981\u958B\u59CB\u3002\r\r"
  - key: 'Run_Enter_Elite '
    lines:
    - "\u5C0F\u5FC3\uFF0C\u9019\u662F\u5927\u5996\u3002\r\n\u7260\u5011\u66F4\u5F37\uFF0C\u4E5F\u66F4\u5371\u96AA\uFF0C\u4F46\u56DE\u5831\u4E5F\u66F4\u8C50\u539A\u3002\r\r\r"
  - key: 'Run_Complete_Elite '
    lines:
    - "\u80FD\u64CA\u6557\u5927\u5996\uFF0C\u4EE3\u8868\u4F60\u5DF2\u7D93\u4E0D\u662F\u65B0\u624B\u4E86\u3002\r\n\u4F46\u5225\u56E0\u6B64\u5927\u610F\u3002\r\r\r\r"
  - key: 'Run_Enter_Rest '
    lines:
    - "\u9019\u88E1\u66AB\u6642\u5B89\u5168\u3002\r\n\u8ABF\u6574\u72C0\u614B\uFF0C\u70BA\u63A5\u4E0B\u4F86\u7684\u8DEF\u505A\u6E96\u5099\u5427\u3002\r\r\r\r"
  - key: 'Run_Enter_Shop '
    lines:
    - "\u5546\u4EBA\u53EA\u770B\u5229\u76CA\uFF0C\u4E0D\u554F\u6B63\u90AA\u3002\r\n\u4ED4\u7D30\u9078\u64C7\uFF0C\u4F60\u7684\u8CC7\u6E90\u6709\u9650\u3002\r"
  - key: 'Run_Complete_Shop '
    lines:
    - "\u7B26\u5492\u8207\u6CD5\u5668\uFF0C\u90FD\u662F\u4FEE\u884C\u7684\u4E00\u90E8\u5206\u3002\r\n\u4F46\u771F\u6B63\u7684\u529B\u91CF\uFF0C\u4ECD\u5728\u4F60\u624B\u4E2D\u3002\r\r"
  - key: 'Run_Enter_Event '
    lines:
    - "\u4E16\u9593\u4E4B\u4E8B\uFF0C\u4E26\u975E\u53EA\u6709\u6230\u9B25\u3002\r\n\u4F60\u7684\u9078\u64C7\uFF0C\u53EF\u80FD\u5E36\u4F86\u610F\u60F3\u4E0D\u5230\u7684\u7D50\u679C\u3002\r\r\r"
  - key: 'Run_Complete_Event '
    lines:
    - "\u56E0\u679C\u5DF2\u5B9A\uFF0C\u8DEF\u4ECD\u8981\u8D70\u4E0B\u53BB\u3002\r\n\u8A18\u4F4F\u9019\u6B21\u7684\u9078\u64C7\u3002\r\r\r\r"
  - key: 'Run_Enter_Boss '
    lines:
    - "\u524D\u65B9\uFF0C\u5C31\u662F\u9019\u689D\u8DEF\u7684\u6E90\u982D\u3002\r\n\u6E96\u5099\u597D\u9762\u5C0D\u771F\u6B63\u7684\u90AA\u795F\u4E86\u55CE\uFF1F\r\r\r\r\r"
  - key: Star_two
    lines:
    - "\u6211\u6703\u6559\u5C0E\u4F60\u6240\u6709\u7684\u5143\u7D20\u53CD\u61C9\uFF0C\u958B\u59CB\u5427\r\r\r\r\r"
    - "\u9019\u662F\u6025\u6025\u5982\u5F8B\u4EE4\u706B\u548C\u6025\u6025\u5982\u5F8B\u4EE4\u6728\uFF0C\u8A66\u8A66\u5427\uFF0C\u6258\u62FD\u5230\u5996\u602A\u8EAB\u4E0A\u4F7F\u7528\r\r\r\r\r"
  - key: Burn
    lines:
    - "\u6ED1\u9F20\u79FB\u81F3\u53D7\u5230\u653B\u64CA\u7684\u5996\u602A\u4E0A\uFF0C\u53EF\u4EE5\u770B\u5230\u5996\u602A\u7684\u72C0\u614B\r\r\r\r\r"
    - "\u706B+\u6728\u6703\u7522\u751F\u71C3\u71D2\u7684\u6548\u679C\uFF0C\u6703\u6B98\u7559\u706B\u5143\u7D20\uFF0C\u71C3\u71D2\u6301\u7E8C5\u56DE\u5408\uFF0C\u6BCF\u6B21\u9020\u62102\u9EDE\u50B7\u5BB3\r\r\r\r\r"
    - "\u5996\u602A\u5728\u71C3\u71D2\u72C0\u614B\u4E0B\uFF0C\u53D7\u5230\u6C34\u5143\u7D20\u6216\u51B0\u5143\u7D20\u50B7\u5BB3\uFF0C\u6703\u56E0\u6B64\u88AB\u6D88\u9664\uFF0C\u8A66\u8A66\u5427\r\r\r\r\r"
  - key: Burntwo
    lines:
    - "\u6ED1\u9F20\u79FB\u81F3\u53D7\u5230\u653B\u64CA\u7684\u5996\u602A\u4E0A\u770B\u770B\uFF0C\u71C3\u71D2\u5DF2\u7D93\u88AB\u79FB\u9664\u4E86\uFF0C\u5996\u602A\u751F\u4E0A\u5247\u6703\u53EA\u4FDD\u7559\u6C34\u5143\u7D20\r\r\r\r\r"
    - "\u505A\u7684\u597D\uFF0C\u63A5\u4E0B\u4F86\u662F\u84B8\u767C\u53CD\u61C9\r\r\r\r\r"
    - "\u9019\u662F\u6025\u6025\u5982\u5F8B\u4EE4\u706B\u548C\u6025\u6025\u5982\u5F8B\u4EE4\u6C34\uFF0C\u8A66\u8A66\u5427\uFF0C\u6258\u62FD\u5230\u5996\u602A\u8EAB\u4E0A\u4F7F\u7528\r\r\r\r\r"
  - key: Evaporation
    lines:
    - "\u706B+\u6C34\u7684\u84B8\u767C\u53CD\u61C9\uFF0C\u6703\u8B93\u5F8C\u8005\u4F7F\u7528\u7684\u50B7\u5BB3\u589E\u52A01.5\u500D\r\r\r\r\r"
    - "\u4E26\u7559\u4E0B\u5F8C\u8005\u653B\u64CA\u7684\u5143\u7D20\r\r\r\r\r"
    - "\u63A5\u4E0B\u4F86\u662F\u96F7\u7206\u53CD\u61C9\r\r\r\r\r"
    - "\u9019\u662F\u6025\u6025\u5982\u5F8B\u4EE4\u96F7\u3001\u6025\u6025\u5982\u5F8B\u4EE4\u706B\r\r\r\r\r"
  - key: Thunderclap
    lines:
    - "\u96F7\u7206\u6703\u5C0D\u88AB\u653B\u64CA\u7684\u5996\u602A\u5468\u570D\u7684\u6575\u4EBA\uFF0C\u4E5F\u9020\u62100.5\u500D\u7684\u50B7\u5BB3\r\r\r\r\r"
    - "\u88AB\u653B\u64CA\u7684\u5996\u602A\u6703\u7559\u4E0B\u5F8C\u8005\u7684\u5143\u7D20\r\r\r\r\r"
    - "\u63A5\u4E0B\u4F86\u662F\u751F\u9577\u53CD\u61C9\r\r\r\r\r"
  - key: Growth
    lines:
    - "\u751F\u9577\u53CD\u61C9\u6703\u5728\u68CB\u76E4\u4E0A\u751F\u9577\u51FA\u834A\u68D8\r\r\r\r\r"
    - "\u834A\u68D8\u6703\u5728\u73A9\u5BB6\u7D50\u675F\u56DE\u5408\u6642\uFF0C\u653B\u64CA\u5728\u834A\u68D8\u683C\u4E0A\u7684\u5996\u602A\u9020\u62103\u9EDE\u50B7\u5BB3\r\r\r\r\r"
    - "\u63A5\u4E0B\u4F86\u662F\u5C0E\u96FB\u53CD\u61C9\r\r\r\r\r"
    - "\u5148\u4F7F\u7528\u6025\u6025\u5982\u5F8B\u4EE4\u6C34\uFF0C\u5728\u4F7F\u7528\u6025\u6025\u5982\u5F8B\u4EE4\u96F7\r\r\r\r\r"
  - key: Conductive
    lines:
    - "\u751F\u9577\u53CD\u61C9\u6703\u5728\u68CB\u76E4\u4E0A\u751F\u9577\u51FA\u834A\u68D8\r\r\r\r\r"
    - "\u834A\u68D8\u6703\u5728\u73A9\u5BB6\u7D50\u675F\u56DE\u5408\u6642\uFF0C\u653B\u64CA\u5728\u834A\u68D8\u683C\u4E0A\u7684\u5996\u602A\u9020\u62103\u9EDE\u50B7\u5BB3\r\r\r\r\r"
    - "\u63A5\u4E0B\u4F86\u662F\u5C0E\u96FB\u53CD\u61C9\r\r\r\r\r"
    - "\u5148\u4F7F\u7528\u6025\u6025\u5982\u5F8B\u4EE4\u6C34\uFF0C\u5728\u4F7F\u7528\u6025\u6025\u5982\u5F8B\u4EE4\u96F7\r\r\r\r\r"
  - key: Freeze
    lines:
    - "\u51B0+\u6C34\u7684\u51B0\u51CD\u53CD\u61C9\uFF0C\u53EF\u4EE5\u51B0\u51CD\u5996\u602A\r\r\r\r\r"
    - "\u8B93\u5996\u602A\u7121\u6CD5\u79FB\u52D5\u548C\u653B\u64CA\r\r\r\r\r"
    - "\u63A5\u4E0B\u4F86\u662F\u7D50\u971C\u53CD\u61C9\r\r\r\r\r"
    - "\u9019\u662F\u6025\u6025\u5982\u5F8B\u4EE4\u51B0\u548C\u6025\u6025\u5982\u5F8B\u4EE4\u6728\r\r\r\r\r"
  - key: Frost
    lines:
    - "\u51B0+\u6728\u7684\u7D50\u971C\u53CD\u61C9\uFF0C\u6703\u8B93\u63A5\u4E0B\u4F86\u9020\u6210\u7684\u50B7\u5BB3\u984D\u5916\u589E\u52A02\u9EDE\u50B7\u5BB3\r\r\r\r\r"
    - "\u6700\u591A\u53EF\u4EE5\u758A\u52A06\u5C64\uFF0C\u6BCF\u73A9\u5BB6\u56DE\u5408\u958B\u59CB\u6642\u6703\u6E1B\u5C111\u5C64\r\r\r\r\r"
    - "\u63A5\u4E0B\u4F86\u662F\u96F7\u64CA\u53CD\u61C9\uFF0C\u9019\u662F\u6025\u6025\u5982\u5F8B\u4EE4\u96F7\u548C\u6025\u6025\u5982\u5F8B\u4EE4\u6728\r\r\r\r\r"
  - key: Lightning strike
    lines:
    - "\u96F7+\u6728\u7684\u96F7\u64CA\u53CD\u61C9\uFF0C\u6703\u8B93\u63A5\u4E0B\u4F86\u9020\u6210\u7684\u50B7\u5BB3\u8B8A\u62102\u500D\r\r\r\r\r"
    - "\u63A5\u4E0B\u4F86\u662F\u878D\u5316\u53CD\u61C9\uFF0C\u9019\u662F\u6025\u6025\u5982\u5F8B\u4EE4\u706B\u548C\u6025\u6025\u5982\u5F8B\u4EE4\u51B0\r\r\r\r\r"
  - key: Melt
    lines:
    - "\u706B+\u51B0\u7684\u878D\u5316\u53CD\u61C9\uFF0C\u6703\u8B93\u5F8C\u8005\u4F7F\u7528\u7684\u50B7\u5BB3\u589E\u52A01.5\u500D\r\r\r\r\r"
    - "\u88AB\u653B\u64CA\u7684\u5996\u602A\u6703\u7559\u4E0B\u5F8C\u8005\u7684\u5143\u7D20\r\r\r\r\r"
    - "\u63A5\u4E0B\u4F86\u662F\u8D85\u5C0E\u53CD\u61C9\", \"\u9019\u662F\u6025\u6025\u5982\u5F8B\u4EE4\u96F7\u548C\u6025\u6025\u5982\u5F8B\u4EE4\u51B0\r\r\r\r\r"
  - key: Superconduct
    lines:
    - "\u96F7+\u51B0\u7684\u8D85\u5C0E\u53CD\u61C9\uFF0C\u6703\u8B93\u5F8C\u653B\u64CA\u7684\u50B7\u5BB3\u589E\u52A06\u9EDE\r\r\r\r\r"
    - "\u9019\u662F\u6559\u5B78\u7684\u6700\u5F8C\u4E00\u500B\u5143\u7D20\u53CD\u61C9\u4E86\uFF0C\u63A5\u4E0B\u4F86\u5C31\u9760\u4F60\u81EA\u5DF1\u53BB\u63A2\u7D22\u4E86\uFF01\r\r\r\r\r"
    - "\u5207\u8A18\uFF0C\u653B\u64CA\u4E00\u500B\u76EE\u6A19\u6642\uFF0C\u4ED6\u6703\u512A\u5148\u548C\u524D\u4E00\u500B\u4F7F\u7528\u7684\u5143\u7D20\u9032\u884C\u53CD\u61C9\r\r\r\r\r"
  - key: Miss
    lines:
    - "\u4F7F\u7528\u7684\u9806\u5E8F\u932F\u4E86\uFF0C\u518D\u4F7F\u7528\u4E00\u6B21\uFF0C\u5148\u4F7F\u7528\u6025\u6025\u5982\u5F8B\u4EE4\u6C34\uFF0C\u5728\u4F7F\u7528\u6025\u6025\u5982\u5F8B\u4EE4\u96F7\r\r\r\r\r"
  - key: Mis
    lines:
    - "\u6025\u6025\u5982\u5F8B\u4EE4\u96F7\u548C\u6025\u6025\u5982\u5F8B\u4EE4\u706B\u9700\u8981\u653B\u64CA\u540C\u4E00\u500B\u5996\u602A\uFF0C\u624D\u80FD\u6B63\u78BA\u7684\u89F8\u767C\u5143\u7D20\u53CD\u61C9\r\r\r\r\r"
